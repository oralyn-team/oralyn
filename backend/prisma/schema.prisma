generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────

enum EstadoCita {
  pendiente
  asistio
  no_asistio
  cancelada
}

enum Sexo {
  masculino
  femenino
  otro
}

enum TipoDocumento {
  RC
  TI
  CC
  CE
  NUIP
  PAS
}

enum TipoConsentimiento {
  anestesia
  cirugia_oral
  retiro_poste_corona
  rehabilitacion
  higiene_oral
}

enum TipoOdontograma {
  GENERAL_ADULTO
  GENERAL_INFANTIL
  ORTODONCIA
}

enum TipoItem {
  detartraje_curetraje
  superficie_retina
  incrustaciones
  carillas
  tratamiento_conducto
  exodoncia
  cirugia
  nucleo
  corona
  blanqueamiento_dental
  otro
}

// ─── CONFIGURACIÓN DEL CONSULTORIO ──────────────────────────

model Configuracion {
  id                   Int      @id @default(autoincrement())
  nombre_consultorio   String
  nombre_profesional   String
  registro_profesional String?
  nit                  String?
  direccion            String?
  telefono             String?
  ciudad               String   @default("Villavicencio")
  email                String?
  logo_url             String?
  creado_en            DateTime @default(now())

  usuarios        Usuario[]
  pacientes       Paciente[]
  citas           Cita[]
  cotizaciones    Cotizacion[]
  pagos           Pago[]
  consentimientos Consentimiento[]
  certificados    CertificadoDental[]
}

// ─── USUARIOS ───────────────────────────────────────────────

model Usuario {
  id             Int           @id @default(autoincrement())
  consultorio_id Int
  consultorio    Configuracion @relation(fields: [consultorio_id], references: [id])
  email          String        @unique
  password_hash  String
  nombre         String
  registro       String?
  creado_en      DateTime      @default(now())
}

// ─── PACIENTES ──────────────────────────────────────────────

model Paciente {
  id                   Int           @id @default(autoincrement())
  consultorio_id       Int
  consultorio          Configuracion @relation(fields: [consultorio_id], references: [id])

  primer_apellido      String
  segundo_apellido     String?
  nombres              String

  tipo_documento       TipoDocumento
  numero_documento     String

  fecha_nacimiento     DateTime
  sexo                 Sexo
  estado_civil         String?
  direccion_residencia String?
  telefono             String?
  correo               String?
  departamento         String?
  municipio_ciudad     String
  ocupacion            String?
  rh                   String?
  clase_seguro         String?
  asegurador           String?
  rango_salarial       String?
  tipo_vinculacion     String?
  nombre_empresa       String?
  acudiente_nombre     String?
  acudiente_parentesco String?
  acudiente_telefono   String?
  creado_en            DateTime @default(now())

  historias       HistoriaClinica[]
  citas           Cita[]
  cotizaciones    Cotizacion[]
  pagos           Pago[]
  consentimientos Consentimiento[]
  certificados    CertificadoDental[]

  @@unique([consultorio_id, numero_documento])
  @@index([consultorio_id])
}

// ─── HISTORIA CLÍNICA ───────────────────────────────────────

model HistoriaClinica {
  id                         Int      @id @default(autoincrement())
  paciente_id                Int
  paciente                   Paciente @relation(fields: [paciente_id], references: [id])
  fecha_atencion             DateTime @default(now())
  motivo_consulta            String
  medicamentos_actuales      String?
  antecedentes_odontologicos String?
  evento_adverso             Boolean  @default(false)
  evento_adverso_obs         String?
  habitos_json               Json?
  habitos_observaciones      String?
  diagnostico                String
  tratamiento_realizado      String?
  observaciones              String?
  recomendaciones            String?
  firma_doctor               String?
  firma_paciente             String?
  departamento               String?
  estado_civil               String?
  direccion                  String?
  ocupacion                  String?
  acudiente                  String?
  parentesco                 String?
  eps                        String?
  tipo_afiliacion            String?
  tipo_sangre                String?
  rh                         String?
  alergias                   String?

  antecedentes           HcAntecedentes?
  examen                 HcExamenEstomatologico?
  odontogramas           HcOdontograma[]
  evoluciones            HojaEvolucion[]
  recomendaciones_postqx RecomendacionPostQx[]
  adjuntos               HcAdjunto[]

  @@index([paciente_id])
}

model HcAntecedentes {
  id                      Int             @id @default(autoincrement())
  historia_id             Int             @unique
  historia                HistoriaClinica @relation(fields: [historia_id], references: [id])
  tratamiento_medicacion  Boolean?
  tratamiento_med_obs     String?
  reacciones_alergicas    Boolean?
  alergias_obs            String?
  problemas_coagulacion   Boolean?
  coagulacion_obs         String?
  irradiaciones           Boolean?
  irradiaciones_obs       String?
  tension_arterial        Boolean?
  tension_obs             String?
  sinusitis               Boolean?
  sinusitis_obs           String?
  enf_respiratorias       Boolean?
  respiratorias_obs       String?
  cardiopatias            Boolean?
  cardiopatias_obs        String?
  diabetes                Boolean?
  diabetes_obs            String?
  fiebre_reumatica        Boolean?
  fiebre_obs              String?
  hepatitis               Boolean?
  hepatitis_obs           String?
  vih                     Boolean?
  vih_obs                 String?
  trastornos_emocionales  Boolean?
  emocionales_obs         String?
  observaciones_generales String?
}

model HcExamenEstomatologico {
  id                 Int             @id @default(autoincrement())
  historia_id        Int             @unique
  historia           HistoriaClinica @relation(fields: [historia_id], references: [id])
  estructuras_json   Json?
  observaciones      String?
  examen_pulpar_json Json?
  pulpar_obs         String?
  tejidos_json       Json?
  tejidos_obs        String?
  periodontal_json   Json?
  dx_periodontal     String?
  periodontal_obs    String?
}

model HcOdontograma {
  id            Int             @id @default(autoincrement())
  historia_id   Int
  historia      HistoriaClinica @relation(fields: [historia_id], references: [id])
  tipo          TipoOdontograma @default(GENERAL_ADULTO)
  dientes_json  Json
  observaciones String?
  creado_en     DateTime        @default(now())
  actualizado_en DateTime       @default(now()) @updatedAt

  @@index([historia_id])
  @@unique([historia_id, tipo])
}

// ─── HOJA DE EVOLUCIÓN ──────────────────────────────────────

model HojaEvolucion {
  id              Int             @id @default(autoincrement())
  historia_id     Int
  historia        HistoriaClinica @relation(fields: [historia_id], references: [id])
  fecha           DateTime
  doctor          String?
  motivo          String?
  diagnostico     String?
  procedimiento   String?
  piezas_tratadas String?
  tratamiento     String?
  estado_clinico  String?
  recomendaciones String?
  proximo_control DateTime?
  observaciones   String?

  @@index([historia_id])
}

model HcAdjunto {
  id               Int             @id @default(autoincrement())
  historia_id      Int
  nombre_archivo   String
  tipo             String?
  mime_type        String?
  tamano_bytes     Int?
  contenido_base64 String?         @db.Text
  url              String?
  creado_en        DateTime        @default(now())
  historia         HistoriaClinica @relation(fields: [historia_id], references: [id], onDelete: Cascade)

  @@index([historia_id])
  @@map("hc_adjuntos")
}

// ─── ENUMS TRATAMIENTOS ─────────────────────────────────────

enum EstadoCotizacion {
  borrador
  pendiente
  aprobado
  en_proceso
  finalizado
  cancelado
}

enum EstadoProcedimiento {
  pendiente
  en_proceso
  realizado
  cancelado
}

enum AplicaEn {
  general
  dientes
  cuadrante
}

enum PrioridadTratamiento {
  baja
  media
  alta
}

enum MetodoPago {
  efectivo
  transferencia_bancaria
  tarjeta_debito
  tarjeta_credito
  nequi
  daviplata
  otro
}

// ─── PLAN DE TRATAMIENTO / COTIZACIÓN ───────────────────────

model Cotizacion {
  id               Int                  @id @default(autoincrement())
  consultorio_id   Int
  consultorio      Configuracion        @relation(fields: [consultorio_id], references: [id])
  paciente_id      Int
  paciente         Paciente             @relation(fields: [paciente_id], references: [id])
  doctor          String?
  doctor_id        Int?
  fecha            DateTime             @default(now())
  tipo_tratamiento String?
  prioridad        PrioridadTratamiento @default(media)
  estado           EstadoCotizacion     @default(borrador)
  motivo           String?
  observaciones    String?
  total            Decimal              @default(0) @db.Decimal(12, 2)
  total_pagado     Decimal              @default(0) @db.Decimal(12, 2)
  saldo            Decimal              @default(0) @db.Decimal(12, 2)
  creado_en        DateTime             @default(now())
  actualizado_en   DateTime             @default(now()) @updatedAt

  procedimientos   ProcedimientoCotizacion[]
  pagos            Pago[]

  @@index([consultorio_id])
  @@index([paciente_id])
  @@index([doctor_id])
}

// ─── PROCEDIMIENTOS DEL TRATAMIENTO ─────────────────────────

model ProcedimientoCotizacion {
  id             Int                 @id @default(autoincrement())
  cotizacion_id  Int
  cotizacion     Cotizacion          @relation(fields: [cotizacion_id], references: [id], onDelete: Cascade)
  procedimiento  String
  descripcion    String?
  aplica_en      AplicaEn            @default(general)
  dientes        Int[]
  cuadrante      String?
  cantidad       Int                 @default(1)
  valor_unitario Decimal             @db.Decimal(10, 2)
  descuento      Decimal             @default(0) @db.Decimal(5, 2)
  subtotal       Decimal             @db.Decimal(12, 2)
  estado         EstadoProcedimiento @default(pendiente)
  observaciones  String?
  orden          Int                 @default(0)

  @@index([cotizacion_id])
}

// ─── PAGOS ──────────────────────────────────────────────────
model Pago {
  id            Int         @id @default(autoincrement())
  consultorio_id Int
  consultorio   Configuracion @relation(fields: [consultorio_id], references: [id])
  paciente_id   Int
  paciente      Paciente    @relation(fields: [paciente_id], references: [id])
  cotizacion_id Int?
  cotizacion    Cotizacion? @relation(fields: [cotizacion_id], references: [id])
  fecha         DateTime    @default(now())
  monto         Decimal     @db.Decimal(10, 2)
  metodo_pago   MetodoPago
  referencia    String?
  concepto      String?
  creado_en     DateTime    @default(now())

  @@index([consultorio_id])
  @@index([paciente_id])
  @@index([cotizacion_id])
}

// ─── CITAS ──────────────────────────────────────────────────

model Cita {
  id                 Int           @id @default(autoincrement())
  consultorio_id     Int
  consultorio        Configuracion @relation(fields: [consultorio_id], references: [id])
  paciente_id        Int
  paciente           Paciente      @relation(fields: [paciente_id], references: [id])
  fecha_hora         DateTime
  doctor             String?
  procedimiento      String
  codigo_cups        String?
  codigo_cie10       String?
  valor_cobrado      Decimal?      @db.Decimal(10, 2)
  estado             EstadoCita    @default(pendiente)
  observaciones      String?
  causas_no_atencion String?
  creado_en          DateTime      @default(now())
  certificados       CertificadoDental[]

  @@index([consultorio_id])
  @@index([paciente_id])
}

model Consentimiento {
  id                        Int                @id @default(autoincrement())
  consultorio_id            Int
  consultorio               Configuracion      @relation(fields: [consultorio_id], references: [id])
  paciente_id               Int
  paciente                  Paciente           @relation(fields: [paciente_id], references: [id])
  tipo                      TipoConsentimiento
  ciudad                    String             @default("Villavicencio")
  fecha                     DateTime           @default(now())
  campos_especificos        Json?
  nombre_paciente_declarado String?
  cc_paciente_declarado     String?
  firma_paciente            String?
  cc_profesional            String?
  firma_doctor              String?
  pdf_generado_en           DateTime?
  anulado                   Boolean            @default(false)
  anulado_en                DateTime?
  motivo_anulacion          String?

  @@index([consultorio_id])
  @@index([paciente_id])
}

model CertificadoDental {
  id               Int           @id @default(autoincrement())
  consultorio_id   Int
  consultorio      Configuracion @relation(fields: [consultorio_id], references: [id])
  paciente_id      Int
  paciente         Paciente      @relation(fields: [paciente_id], references: [id])
  cita_id          Int?
  cita             Cita?         @relation(fields: [cita_id], references: [id])
  tipo_cita_texto  String
  ciudad           String        @default("Villavicencio")
  fecha_expedicion DateTime
  creado_en        DateTime      @default(now())
  anulado          Boolean       @default(false)
  anulado_en       DateTime?
  motivo_anulacion String?

  @@index([consultorio_id])
  @@index([paciente_id])
}

// ─── RECOMENDACIONES POST-QX ────────────────────────────────

model RecomendacionPostQx {
  id          Int              @id @default(autoincrement())
  historia_id Int?
  historia    HistoriaClinica? @relation(fields: [historia_id], references: [id])
  fecha       DateTime
  creado_en   DateTime         @default(now())
}
